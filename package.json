{
  "name": "terrova",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--max-old-space-size=4096 next dev",
    "dev:fresh": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && npm run dev",
    "dev:stable": "cross-env NODE_OPTIONS=--max-old-space-size=4096 next dev --webpack",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint",
    "seed": "node scripts/seed-sanity.mjs",
    "seed:sanity": "node scripts/seed-sanity.mjs"
  },
  "dependencies": {
    "@sanity/image-url": "^2.1.1",
    "@sanity/vision": "^5.19.0",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.101.1",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "clsx": "^2.1.1",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.36.0",
    "lenis": "^1.3.23",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "next-intl": "^4.9.1",
    "next-sanity": "^12.2.1",
    "posthog-js": "^1.372.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^6.10.0",
    "sanity": "^5.19.0",
    "stripe": "^21.0.1",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^7.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.1"
  }
}
