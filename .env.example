# ═══════════════════════════════════════════════════════════════════════════
# Terravoa — copy to .env.local and fill in. Never commit real secrets.
# ═══════════════════════════════════════════════════════════════════════════

# ── Public site URL ─────────────────────────────────────────────────────────
# Production: https://www.terravoa.com (no trailing slash)
# On Vercel, if unset, https://<VERCEL_URL> is used (see next.config.ts).
# NEXT_PUBLIC_SITE_URL=https://www.terravoa.com

# Registered office (shown on Terms, Privacy, Returns). Recommended before launch.
# NEXT_PUBLIC_COMPANY_REGISTERED_ADDRESS=Your Street, Postal Code, City, France

# Impressum / Mentions légales — required for DE/AT launch (TMG §5) and
# recommended in FR (LCEN Art. 6-III). Each field falls back to a visible
# [TO FILL: …] placeholder if unset; the launch checklist gates go-live on
# every field being populated. See docs/LAUNCH-CHECKLIST.md §7.2.
# NEXT_PUBLIC_COMPANY_MANAGING_DIRECTOR="Jane Doe"
# NEXT_PUBLIC_COMPANY_REGISTRATION="RCS Paris 123 456 789"
# NEXT_PUBLIC_COMPANY_SIRET="12345678901234"
# NEXT_PUBLIC_COMPANY_SHARE_CAPITAL="10 000 €"
# NEXT_PUBLIC_COMPANY_VAT_ID="FR12345678901"
# NEXT_PUBLIC_COMPANY_PHONE="+33 1 23 45 67 89"
# NEXT_PUBLIC_COMPANY_CONTACT_EMAIL="hello@terravoa.com"
# NEXT_PUBLIC_COMPANY_HOSTING_PROVIDER="Vercel Inc., 440 N Barranca Ave #4133, Covina, CA 91723, USA — vercel.com"

# Search Console (optional): paste the content value from Google’s verification meta tag.
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Optional: canonical social/profile URLs for JSON-LD sameAs (Twitter/X, LinkedIn, etc.)
# NEXT_PUBLIC_SOCIAL_PROFILE_URL_1=https://twitter.com/terravoa_eu
# NEXT_PUBLIC_SOCIAL_PROFILE_URL_2=

# Allow search engines to index the site (use only when ready to go live)
# NEXT_PUBLIC_ROBOTS_INDEX=true

# ── Supabase ────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe (checkout + webhooks) ───────────────────────────────────────────
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# ── Resend (transactional email) ─────────────────────────────────────────────
# RESEND_API_KEY=
# EMAIL_FROM=Terravoa <hello@terravoa.com>
# Admin recipient for operational alerts and escalation digests
# ADMIN_CONTACT_EMAIL=ops@terravoa.com

# Comma-separated staff emails allowed to use /admin (case-insensitive).
# ADMIN_EMAILS=you@terravoa.com

# ── Cron + health-check auth ────────────────────────────────────────────────
# Shared secret for POST /api/cron/* and GET /api/health/*
# Send as: Authorization: Bearer <CRON_SECRET>
# Vercel Cron is pre-configured to send this header, no extra setup needed.
# CRON_SECRET=

# Optional deprecation flag. If set to 'true', cron routes also accept the
# legacy `x-cron-secret` header. Leave unset in new deployments.
# ALLOW_LEGACY_CRON_HEADER=

# ── Rate limiter — Upstash Redis (production) ───────────────────────────────
# Required on Vercel / any serverless runtime. Without these the limiter falls
# back to an in-memory Map, which is useless across cold-start isolates.
#
# Setup:
#   1. Create a free Redis database at https://console.upstash.com
#   2. Copy "UPSTASH_REDIS_REST_URL" and "UPSTASH_REDIS_REST_TOKEN" from the
#      database's REST API tab into your Vercel project env (all environments).
#   3. Verify with:
#        curl -H "Authorization: Bearer $CRON_SECRET" \
#             https://<your-domain>/api/health/rate-limit
#      Response should show `"healthy": true` and `"redis.configured": true`.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ── Sanity CMS (content for products, producers, regions, journal — optional) ─
# Without these, the site uses Supabase (if data exists) or built-in demo JSON.
# NEXT_PUBLIC_SANITY_PROJECT_ID=
# NEXT_PUBLIC_SANITY_DATASET=production
# Server-only write token for `npm run seed:sanity` (create at sanity.io/manage → API → Tokens)
# SANITY_TOKEN=

# Public routes use locale prefixes: /en/..., /de/..., /fr/..., etc.
# Add Supabase Auth redirect URLs for each locale path you use.

# Feature flags (set to 'true' to activate)
# NEXT_PUBLIC_FEATURE_GIFT_MESSAGING=true
# NEXT_PUBLIC_FEATURE_PRODUCER_MESSAGING=true
# NEXT_PUBLIC_FEATURE_BATCH_TRACEABILITY=true
# NEXT_PUBLIC_FEATURE_ADOPT_PRODUCER=true
